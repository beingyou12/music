   "cell_type": "code",
   "source": [
    "# ============================================================\n",
    "# Data-driven quadrant thresholds via KDE valley detection\n",
    "# ============================================================\n",
    "from scipy.stats import gaussian_kde\n",
    "from scipy.signal import argrelextrema\n",
    "\n",
    "valid_annot = annotations[annotations['song_id'].isin(mel_spectrograms.keys())].copy()\n",
    "\n",
    "\n",
    "def find_kde_valley(values, grid_points=1000):\n",
    "    \"\"\"\n",
    "    Find the valley (local minimum) in the KDE of a 1-D array of values.\n",
    "    The valley represents the natural split point in a bimodal distribution.\n",
    "\n",
    "    Returns:\n",
    "        (valley_value, kde_x, kde_y) — the x-coordinate of the valley,\n",
    "        plus the full KDE curve for plotting.\n",
    "    \"\"\"\n",
    "    kde = gaussian_kde(values, bw_method='scott')\n",
    "    x_grid = np.linspace(values.min() - 0.5, values.max() + 0.5, grid_points)\n",
    "    kde_y = kde(x_grid)\n",
    "\n",
    "    # Find local minima\n",
    "    local_min_indices = argrelextrema(kde_y, np.less, order=20)[0]\n",
    "\n",
    "    if len(local_min_indices) > 0:\n",
    "        # Pick the minimum closest to the center of the range\n",
    "        center = np.median(values)\n",
    "        dists = np.abs(x_grid[local_min_indices] - center)\n",
    "        best_idx = local_min_indices[np.argmin(dists)]\n",
    "        valley = float(x_grid[best_idx])\n",
    "    else:\n",
    "        # Unimodal: use median as threshold\n",
    "        valley = float(np.median(values))\n",
    "        print(f\"  ⚠ No valley found (unimodal distribution), using median = {valley:.3f}\")\n",
    "\n",
    "    return valley, x_grid, kde_y\n",
    "\n",
    "\n",
    "# Find valley thresholds\n",
    "valence_vals = valid_annot['valence_mean'].values\n",
    "arousal_vals = valid_annot['arousal_mean'].values\n",
    "\n",
    "print(\"Finding data-driven quadrant thresholds via KDE valley detection...\")\n",
    "VALENCE_THRESHOLD, val_x, val_kde = find_kde_valley(valence_vals)\n",
    "AROUSAL_THRESHOLD, aro_x, aro_kde = find_kde_valley(arousal_vals)\n",
    "\n",
    "print(f\"\\n  Valence threshold (valley): {VALENCE_THRESHOLD:.3f}  (old hardcoded: 5.0)\")\n",
    "print(f\"  Arousal threshold (valley): {AROUSAL_THRESHOLD:.3f}  (old hardcoded: 5.0)\")\n",
    "\n",
    "# --- Visualize KDE with thresholds ---\n",
    "fig, axes = plt.subplots(1, 2, figsize=(16, 5))\n",
    "\n",
    "axes[0].fill_between(val_x, val_kde, alpha=0.3, color='steelblue')\n",
    "axes[0].plot(val_x, val_kde, color='steelblue', lw=2)\n",
    "axes[0].axvline(x=VALENCE_THRESHOLD, color='red', linestyle='--', lw=2, label=f'Valley = {VALENCE_THRESHOLD:.2f}')\n",
    "axes[0].axvline(x=5.0, color='gray', linestyle=':', lw=1.5, label='Old threshold = 5.0')\n",
    "axes[0].set_xlabel('Valence Mean')\n",
    "axes[0].set_ylabel('Density')\n",
    "axes[0].set_title('Valence Distribution — KDE Valley Detection')\n",
    "axes[0].legend()\n",
    "\n",
    "axes[1].fill_between(aro_x, aro_kde, alpha=0.3, color='coral')\n",
    "axes[1].plot(aro_x, aro_kde, color='coral', lw=2)\n",
    "axes[1].axvline(x=AROUSAL_THRESHOLD, color='red', linestyle='--', lw=2, label=f'Valley = {AROUSAL_THRESHOLD:.2f}')\n",
    "axes[1].axvline(x=5.0, color='gray', linestyle=':', lw=1.5, label='Old threshold = 5.0')\n",
    "axes[1].set_xlabel('Arousal Mean')\n",
    "axes[1].set_ylabel('Density')\n",
    "axes[1].set_title('Arousal Distribution — KDE Valley Detection')\n",
    "axes[1].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# Emotion mapping using data-driven thresholds\n",
    "# ============================================================\n",
    "MARGIN = 0.0  # Retain ALL songs — no borderline filtering\n",
    "\n",
    "def map_emotion(valence, arousal, val_threshold=VALENCE_THRESHOLD,\n",
    "                aro_threshold=AROUSAL_THRESHOLD, margin=MARGIN):\n",
    "    \"\"\"\n",
    "    Map valence and arousal values to emotion categories using Russell's\n",
    "    Circumplex Model with DATA-DRIVEN thresholds (KDE valley detection).\n",
    "\n",
    "    Parameters:\n",
    "        valence: Valence value (1-9 scale)\n",
    "        arousal: Arousal value (1-9 scale)\n",
    "        val_threshold: Valence split (from KDE valley)\n",
    "        aro_threshold: Arousal split (from KDE valley)\n",
    "        margin: Distance from threshold within which samples are considered ambiguous\n",
    "\n",
    "    Returns:\n",
    "        Emotion category string, or None if ambiguous\n",
    "    \"\"\"\n",
    "    if abs(valence - val_threshold) < margin or abs(arousal - aro_threshold) < margin:\n",
    "        return None\n",
    "\n",
    "    if valence >= val_threshold and arousal >= aro_threshold:\n",
    "        return \"Happy/Excited\"\n",
    "    elif valence < val_threshold and arousal >= aro_threshold:\n",
    "        return \"Angry/Tense\"\n",
    "    elif valence < val_threshold and arousal < aro_threshold:\n",
    "        return \"Sad/Depressed\"\n",
    "    else:  # valence >= val_threshold and arousal < aro_threshold\n",
    "        return \"Calm/Relaxed\"\n",
    "\n",
    "\n",
    "# Apply emotion mapping\n",
    "valid_annot['emotion'] = valid_annot.apply(\n",
