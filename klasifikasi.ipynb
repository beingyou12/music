    "\n",
    "axes[1].axhline(y=5, color='black', linestyle='--', alpha=0.5)\n",
    "axes[1].axvline(x=5, color='black', linestyle='--', alpha=0.5)\n",
    "axes[1].set_xlabel('Valence')\n",
