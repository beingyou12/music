    "# ============================================================\n",
    "# Compact CNN Setup — reproducible training on spectrogram crops\n",
    "# ============================================================\n",
    "import math\n",
    "import random\n",
    "from collections import defaultdict\n",
    "\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras import layers, callbacks, regularizers\n",
    "\n",
