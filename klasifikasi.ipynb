    "valid_annot = valid_annot.dropna(subset=['emotion']).reset_index(drop=True)\n",
    "n_dropped = n_before - len(valid_annot)\n",
    "print(f\"\\nDropped {n_dropped} ambiguous borderline samples (margin={MARGIN})\")\n",
